# Copy to .env and fill in. Used by app/config.py (python-dotenv).

# SQLite file path (default: tamilnadu_products.db next to this folder)
# SQLITE_PATH=./tamilnadu_products.db

# Optional async URL override (must be sqlite+... or sqlite:///...)
# DATABASE_URL=

JWT_SECRET=8f7c2d1a9b4e6f3c5d8a1e7b9c2f4a6d3e8f1b5c7a9d2e4f6b8c1a3d5e7f9a2
FRONTEND_URL=https://www.tamilnaduproducts.com

# SMTP for OTP email delivery
# Example for Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_FROM_NAME=Tamil Nadu Products
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Tamil Nadu Products
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Railway / hosting
# PORT=8000

# Razorpay (https://dashboard.razorpay.com → Account & Settings → API Keys)
# Use "Test mode" keys for development; switch to Live keys in production.
# Key ID is safe to expose to the browser; Key Secret must stay only on the server.
# The shop loads Key ID from GET /api/payments/config (from these env vars).
RAZORPAY_KEY_ID=rzp_live_SdcFjLjrfMbp6H
RAZORPAY_KEY_SECRET=0wepSBS2EO0zdDJ3GljLMXXJ

# Uploads directory relative to backend/ (default: uploads)
# UPLOAD_PATH=uploads
# MAX_FILE_SIZE=5242880
